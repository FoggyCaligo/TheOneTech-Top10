# 네이버 개발자 센터에서 검색 API 사용 애플리케이션을 등록한 뒤 입력합니다.
NAVER_CLIENT_ID=replace-me
NAVER_CLIENT_SECRET=replace-me

# 쉼표로 여러 지역/검색어를 설정할 수 있습니다.
NEWS_QUERIES=서울,광주,대전

# 비워 두면 네이버 검색 결과 전체를 저장합니다.
# 메이저 언론사만 남기려면 원문 도메인을 쉼표로 입력하세요.
# 예: yna.co.kr,kbs.co.kr,imnews.imbc.com,sbs.co.kr,chosun.com,joongang.co.kr,donga.com,hani.co.kr,khan.co.kr,hankookilbo.com
NEWS_PUBLISHER_DOMAINS=

NEWS_DB_PATH=data/news.db
NEWS_RETENTION_DAYS=365

# 네이버 공식 제한: display 최대 100, start 최대 1000
NAVER_PAGE_SIZE=100
NAVER_MAX_RESULTS_PER_QUERY=1000
NAVER_TIMEOUT_SECONDS=20
NAVER_REQUEST_DELAY_SECONDS=0.1
