# 승인 후 제공받은 실제 검색 API URL과 키를 입력하세요.
BIGKINDS_API_URL=https://example.bigkinds.or.kr/api/news/search
BIGKINDS_API_KEY=replace-me

# 인증 방식이 다르면 승인 명세에 맞게 변경합니다.
BIGKINDS_AUTH_HEADER=Authorization
BIGKINDS_AUTH_SCHEME=Bearer

# 응답 JSON 내 기사 배열/총건수 위치입니다. 점 표기법을 지원합니다.
BIGKINDS_ITEMS_PATH=documents
BIGKINDS_TOTAL_PATH=total_hits

BIGKINDS_PAGE_SIZE=100
BIGKINDS_MAX_PAGES=1000
BIGKINDS_TIMEOUT_SECONDS=30
