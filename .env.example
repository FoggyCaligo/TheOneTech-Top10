# 네이버 개발자 센터에서 검색 API 사용 애플리케이션을 등록한 뒤 입력합니다.
NAVER_CLIENT_ID=replace-me
NAVER_CLIENT_SECRET=replace-me

# 매일 증분 수집할 지역 검색어입니다. 쉼표로 여러 개를 설정할 수 있습니다.
NEWS_QUERIES=서울,광주,대전

# 초기 적재와 일일 적재 모두 아래 원문 도메인만 저장합니다.
# 필요하면 회사 기준에 맞게 추가하거나 제거할 수 있습니다.
NEWS_PUBLISHER_DOMAINS=yna.co.kr,newsis.com,news1.kr,kbs.co.kr,imnews.imbc.com,imbc.com,sbs.co.kr,ytn.co.kr,jtbc.co.kr,tvchosun.com,mbn.co.kr,channela.com,chosun.com,joongang.co.kr,donga.com,hani.co.kr,khan.co.kr,hankookilbo.com,kmib.co.kr,munhwa.com,segye.com,seoul.co.kr,mk.co.kr,hankyung.com,sedaily.com,asiae.co.kr,edaily.co.kr,fnnews.com,heraldcorp.com

NEWS_DB_PATH=data/news.db
NEWS_RETENTION_DAYS=365

# 네이버 공식 제한: display 최대 100, start 최대 1000
NAVER_PAGE_SIZE=100
NAVER_MAX_RESULTS_PER_QUERY=1000
NAVER_TIMEOUT_SECONDS=20
NAVER_REQUEST_DELAY_SECONDS=0.1

# 앱에서 "빅카인즈 API" 소스를 고를 때 사용합니다.
BIGKINDS_ACCESS_KEY=replace-me
BIGKINDS_ENDPOINT=https://tools.kinds.or.kr/search/news
BIGKINDS_PAGE_SIZE=100
BIGKINDS_MAX_RESULTS_PER_QUERY=1000
BIGKINDS_TIMEOUT_SECONDS=30

# 앱에서 "빅카인즈 다운로드 파일" 소스를 고를 때 읽을 기본 경로입니다.
# csv, xlsx, xls를 지원합니다.
BIGKINDS_DOWNLOAD_PATH=Top10_experiment/NewsResult_20250715-20260715.csv
